public class Student {
    private int studentID;
    private String firstName;
    private String lastName;
    private String email;
    private int age;
    private int[] grades = new int[3];

    public Student(int studentID, String firstName, String lastName, String email, int age, int[] grades) {
        this.studentID = studentID;
        this.firstName = firstName;
        this.lastName = lastName;
        this.email = email;
        this.age = age;
        this.grades = grades;
    }


    public int getStudentID() {
        System.out.println(studentID);
    }

    public void setStudentID(int newStudentID) {
        this.studentID = studentID;
    }

    public String getFirstName() {
        System.out.println(firstName);
    }

    public void setFirstName(String newFirstname) {
        this.firstName = newFirstname;
    }

    public String getLastName() {
        System.out.println(lastName);
    }

    public void setLastName(String newLastname) {
        this.lastName = newLastname;
    }

    public String getEmail() {
        System.out.println(email);
    }

    public void setEmail(String newEmail) {
        this.email = newEmail;
    }

    public int getAge() {
        System.out.println(age);
    }

    public void setAge(int newAge) {
        this.age = newAge;
    }

    public int[] getGrades() {
        System.out.println(grades);
    }

    public void setGrades(int[] newGrades) {
        this.grades = newGrades;
    }

    public void print() {
        System.out.println(getStudentID()   + "\t First Name: " + getFirstName() + "\t Last Name: " + getLastName() + ",\t Email: " + getEmail() + "\t Age: " + getAge() + "\t Grades: {" + Arrays.toString(getGrades()) + "}");
    }
}


public class Student_Roster {
    private ArrayList<Student> classRoster = new ArrayList<>();

    public void add(String studentID, String firstName, String lastName, String email, int age, int[] grades) {
        setStudentID(studentID);
        setFirstName(firstName);
        setLastName(lastName);
        setEmail(email);
        setAge(age);
        setGrades(grades);
    }

    public void remove(String studentID) {
        if (classRoster.contains(studentID)) {
            classRoster.remove(studentID);
        } else {
            System.out.println("Student with ID " + studentID + " not found.");
        }
    }

    public void print_all() {
        for (Student s : classRoster) {
            s.print();
        }
    }

    public void print_average_grade(String studentID) {
        int[] grades = classRoster.get(studentID).getGrades();
        double average = Arrays.stream(grades).average().orElse(0.0);
        System.out.println("Average grade for student " + studentID + ": " + average);
    }

    public void print_invalid_emails() {
        for (Student s : classRoster) {
            String email = s.getEmail();
            if (!email.contains("@") || !email.contains(".") || email.contains(" ")) {
                System.out.println("Invalid email: " + email);
            }
        }

    }
}
